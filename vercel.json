{
    "version": 2,
    "builds": [
      {
        "src": "app/main.py",
        "use": "@vercel/python",
        "config": {
          "pythonVersion": "3.10",
          "installCommand": "pip install --upgrade pip setuptools wheel && pip install -r requirements.txt",
          "includeFiles": "firebase-service-account.json|.env",
          "maxLambdaSize": "15mb",
          "memory": 3008,
          "maxDuration": 30
        }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "app/main.py"
      }
    ]
  }
  